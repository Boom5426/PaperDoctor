{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PaperDoctor Section Roles",
  "type": "object",
  "required": ["document_name", "supported_roles", "item_count", "items"],
  "properties": {
    "document_name": { "type": "string" },
    "supported_roles": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "background",
          "gap",
          "objective",
          "contribution",
          "method",
          "result",
          "interpretation",
          "limitation",
          "significance",
          "transition",
          "non_core"
        ]
      }
    },
    "item_count": { "type": "integer", "minimum": 0 },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["paragraph_id", "section", "role", "confidence", "rationale", "source_text"],
        "properties": {
          "paragraph_id": { "type": "string" },
          "section": { "type": "string" },
          "role": {
            "type": "string",
            "enum": [
              "background",
              "gap",
              "objective",
              "contribution",
              "method",
              "result",
              "interpretation",
              "limitation",
              "significance",
              "transition",
              "non_core"
            ]
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "rationale": { "type": "string" },
          "source_text": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
