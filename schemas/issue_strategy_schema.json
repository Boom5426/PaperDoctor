{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PaperDoctor Issue Strategy",
  "type": "object",
  "required": ["document_name", "item_count", "items"],
  "properties": {
    "document_name": { "type": "string" },
    "item_count": { "type": "integer", "minimum": 0 },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "cluster_id",
          "issue_type",
          "section",
          "problem",
          "action",
          "rationale"
        ],
        "properties": {
          "cluster_id": { "type": "string" },
          "issue_type": { "type": "string" },
          "section": { "type": "string" },
          "problem": { "type": "string" },
          "action": {
            "type": "string",
            "enum": ["fix", "reframe", "defer"]
          },
          "rationale": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
